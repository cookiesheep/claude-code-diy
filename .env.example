# ============================================================
# claude-code-diy Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- API Authentication (choose one) ---

# Standard API Key (sent via x-api-key header)
ANTHROPIC_API_KEY=your-api-key-here

# Or: Bearer Token (sent via Authorization header)
# ANTHROPIC_AUTH_TOKEN=your-token-here

# --- API Endpoint (optional) ---
# Default: https://api.anthropic.com
# For third-party proxies, set to your proxy base URL
# (must support Anthropic Messages API format: /v1/messages)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Model Configuration ---
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Model aliases (optional - map sonnet/haiku/opus to your preferred models)
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-20250514

# --- Timeout ---
# API_TIMEOUT_MS=600000

# --- Telemetry ---
# Set to 1 to disable telemetry and non-essential network requests
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
